# Code Snippets sync: raw exports, generated imports, and reports can contain
# local absolute paths, export filenames, and full snippet payloads
/CODE_SNIPPETS_SYNC/exports/*.json
/CODE_SNIPPETS_SYNC/exports/*.xml
/CODE_SNIPPETS_SYNC/exports/extracted-online-current/
/CODE_SNIPPETS_SYNC/imports/*.json
/CODE_SNIPPETS_SYNC/reports/*.json
/CODE_SNIPPETS_SYNC/reports/*.md
/CODE_SNIPPETS_SYNC/secrets/*.env

# Keep explanatory docs in sync folders
!/CODE_SNIPPETS_SYNC/exports/README.md
!/CODE_SNIPPETS_SYNC/README.md
!/CODE_SNIPPETS_SYNC/secrets/wp-sync.env.example

